{
  "os": "windows",
  "pagecache": [],
  "lineage": [
    {
      "id": "office_spawns_shell",
      "level": "alert",
      "technique": "T1059.001",
      "detail": "Office application spawned a script interpreter (macro exec)",
      "match": {
        "parent_comm_in": [
          "winword.exe",
          "excel.exe",
          "powerpnt.exe",
          "outlook.exe"
        ],
        "child_comm_in": [
          "powershell.exe",
          "cmd.exe",
          "wscript.exe",
          "cscript.exe",
          "mshta.exe"
        ]
      }
    },
    {
      "id": "browser_spawns_shell",
      "level": "warn",
      "technique": "T1059",
      "detail": "Browser spawned a shell (drive-by / exploit)",
      "match": {
        "parent_comm_in": [
          "chrome.exe",
          "msedge.exe",
          "firefox.exe",
          "iexplore.exe"
        ],
        "child_comm_in": [
          "cmd.exe",
          "powershell.exe"
        ]
      }
    },
    {
      "id": "wmiexec_signature",
      "level": "alert",
      "technique": "T1047",
      "detail": "wmiprvse spawning cmd /Q /c (Impacket wmiexec lateral movement)",
      "match": {
        "parent_comm_in": [
          "wmiprvse.exe"
        ],
        "child_comm_in": [
          "cmd.exe"
        ]
      }
    },
    {
      "id": "services_spawns_shell",
      "level": "warn",
      "technique": "T1543.003",
      "detail": "services.exe spawned a shell (service persistence)",
      "match": {
        "parent_comm_in": [
          "services.exe"
        ],
        "child_comm_in": [
          "cmd.exe",
          "powershell.exe"
        ]
      }
    }
  ],
  "command": [
    {
      "id": "encoded_powershell",
      "level": "alert",
      "technique": "T1059.001",
      "detail": "Encoded PowerShell command (obfuscation)",
      "match": {
        "cmd_regex": "powershell.*(-enc|-encodedcommand|-e\\s|frombase64string)",
        "cmd_flags": "i"
      }
    },
    {
      "id": "download_cradle",
      "level": "warn",
      "technique": "T1105",
      "detail": "PowerShell download cradle",
      "match": {
        "cmd_regex": "(downloadstring|downloadfile|invoke-webrequest|iwr|certutil.*-urlcache)",
        "cmd_flags": "i"
      }
    },
    {
      "id": "wmiexec_redirect",
      "level": "alert",
      "technique": "T1047",
      "detail": "Impacket wmiexec output redirection to ADMIN$ share",
      "match": {
        "cmd_regex": "cmd\\.exe\\s+/q\\s+/c.*\\\\\\\\127\\.0\\.0\\.1\\\\admin\\$",
        "cmd_flags": "i"
      }
    },
    {
      "id": "shadow_copy_delete",
      "level": "alert",
      "technique": "T1490",
      "detail": "Volume shadow copy deletion (ransomware precursor)",
      "match": {
        "cmd_regex": "(vssadmin.*delete\\s+shadows|wmic\\s+shadowcopy\\s+delete|bcdedit.*recoveryenabled\\s+no)",
        "cmd_flags": "i"
      }
    }
  ],
  "network": [
    {
      "id": "listening_high_port",
      "level": "warn",
      "technique": "T1571",
      "detail": "Process listening on a non-standard high port",
      "match": {
        "state_in": [
          "LISTENING",
          "LISTEN"
        ],
        "local_port_gte": 1024,
        "local_port_not_in": [
          3389,
          5985,
          5986,
          8080,
          8443
        ]
      }
    }
  ],
  "spoofing": [],
  "malfind": [
    {
      "id": "rwx_region",
      "level": "warn",
      "technique": "T1055.012",
      "detail": "RWX / executable private memory (process injection)",
      "match": {
        "field_truthy": "rwx"
      }
    }
  ],
  "modules": [],
  "syscalls": []
}